  "title": "Bài 0: Pinyin & 4 thanh điệu",
  "level": "pinyin",
  "intro": "Tiếng Trung có 4 thanh điệu chính + khinh thanh. Cùng một âm 'ma' nhưng khác thanh là khác nghĩa. Thanh 1: cao và bằng (ā). Thanh 2: đi lên như hỏi (á). Thanh 3: xuống rồi lên (ǎ). Thanh 4: xuống dứt khoát (à). Khinh thanh: nhẹ, ngắn (a). Hãy nghe và lặp lại từng âm.",
  "vocab": [
    { "hanzi": "妈", "pinyin": "mā", "vi": "mẹ (thanh 1 – cao bằng)", "tones": [1] },
    { "hanzi": "麻", "pinyin": "má", "vi": "cây gai (thanh 2 – đi lên)", "tones": [2] },
    { "hanzi": "马", "pinyin": "mǎ", "vi": "con ngựa (thanh 3 – xuống rồi lên)", "tones": [3] },
